APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Production (Plesk): APP_ENV=production, APP_DEBUG=false
APP_URL=https://www.chaiyo-factory.com

# โดเมนที่ Sanctum ยอมรับ cookie (ไม่มีช่องว่างหลัง comma)
# รวมทั้งมี/ไม่มี www ถ้าเปิดให้เข้าได้สองแบบ
SANCTUM_STATEFUL_DOMAINS=www.chaiyo-factory.com,chaiyo-factory.com,localhost,localhost:8000,127.0.0.1,127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# Plesk: ใช้ค่าจากเมนู Databases (รหัสมี $ ให้ใส่ในเครื่องหมายคำพูด เช่น DB_PASSWORD="...")
# DB_SOCKET=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# ถ้าใช้ทั้ง www และ apex แล้ว session หลุด ลอง: SESSION_DOMAIN=.chaiyo-factory.com
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
# Dev: ต้องตรงกับที่รัน npm run dev
VITE_DEV_SERVER_URL=http://localhost:5173
VITE_HMR_HOST=localhost
# Dev บน LAN: ใช้ http://<IP>:5173 และ VITE_HMR_HOST=<IP>

# Google Apps Script — Production Monitor
GAS_PRODUCTION_URL=https://script.google.com/macros/s/AKfycbzg1FRP4zDvgJpIQmgLAGBPM9EpUbjndLmEOWD52WlL6U-ixhm4GZu9kESCZDWJn05o/exec
GAS_PLAN_URL=https://script.google.com/macros/s/AKfycbxlbbA1oZD1j7aoB6_-CB5dh7Z1_aPDpTYk1Re6KUp3yKEC6Wa9WHYxeSP_WI1gQ2fm/exec
GAS_MACHINE_LOG_URL=https://script.google.com/macros/s/AKfycbxOhMVIO5HSkgM9ERA8YC8TfPT-2jgj2xyQWkxZMdNm2QsdwBZ_exjny3Qr1Cee80sa_w/exec
